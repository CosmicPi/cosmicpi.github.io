source "https://rubygems.org"
ruby RUBY_VERSION

# This site is built with GitHub Pages. Using the github-pages gem ensures
# all dependencies are pinned to secure, compatible versions maintained by
# GitHub. No manual vulnerability management needed.
#
# To build locally: bundle install && bundle exec jekyll serve
gem "github-pages", group: :jekyll_plugins

# If you have any plugins, put them here!
group :jekyll_plugins do
   gem "jekyll-feed", "~> 0.6"
end
